# Copy to .env and fill in values before running docker compose up

# How long to run each browser session (seconds). 90 captures preroll + first midroll.
SESSION_DURATION_S=90

# Where artifacts land inside the container (matches the volume mount in compose)
ARTIFACT_DIR=/app/artifacts

# SQLite database path inside the container
DB_PATH=/app/data/competitool.db

# REDIS_URL is set automatically by docker-compose; override here only if using an external Redis
# REDIS_URL=redis://redis:6379
